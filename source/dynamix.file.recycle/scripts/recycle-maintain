#!/bin/bash
# scripts/recycle-maintain — invoked only by the user's generated cron entry.
#
# Thin wrapper that hands off to the PHP Bootstrap CLI. Keeps the cron entry
# minimal and avoids re-implementing maintenance logic in bash.
set -uo pipefail

# Prefer Unraid's current PHP path, retain the older path as a fallback.
if [ -z "${PHP_BIN:-}" ]; then
    for candidate in /usr/bin/php /usr/local/bin/php; do
        if [ -x "$candidate" ]; then PHP_BIN="$candidate"; break; fi
    done
fi
if [ -z "${PHP_BIN:-}" ]; then PHP_BIN="$(command -v php || true)"; fi
if [ -z "$PHP_BIN" ]; then
    echo "dynamix.file.recycle: php interpreter not found, aborting" >&2
    exit 0   # do not fail cron
fi

PLUGIN_DIR="/usr/local/emhttp/plugins/dynamix.file.recycle"
BOOT="$PLUGIN_DIR/include/Bootstrap.php"
if [ ! -f "$BOOT" ]; then
    echo "dynamix.file.recycle: $BOOT not found (plugin removed?)" >&2
    exit 0
fi

[[ "${1:-}" == "scheduled" ]] || { echo "scheduled invocation required" >&2; exit 2; }
exec "$PHP_BIN" "$BOOT" maintain-scheduled
