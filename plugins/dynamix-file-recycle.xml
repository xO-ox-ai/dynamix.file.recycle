  <Support>https://github.com/xO-ox-ai/dynamix.file.recycle/issues</Support>
  <Project>https://github.com/xO-ox-ai/dynamix.file.recycle</Project>
  <ReadMe>https://raw.githubusercontent.com/xO-ox-ai/dynamix.file.recycle/main/README.md</ReadMe>
  <Category>Tools:Utilities</Category>
  <Beta>true</Beta>
