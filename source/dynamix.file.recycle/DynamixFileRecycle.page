<link rel="stylesheet" href="<?autov('/plugins/dynamix.file.recycle/javascript/settings.css')?>&amp;plugin=<?=rawurlencode($recycleAssetVersion)?>">

<div id="recycle-settings" class="recycle-settings">
  <div id="recycle-settings-notice" class="recycle-settings-notice" role="status" aria-live="polite"></div>

  <p class="recycle-settings-intro" data-i18n="intro">
    Move files to a per-volume .RecycleBin instead of deleting them permanently.
  </p>

  <form id="recycle-settings-form" autocomplete="off">
    <section class="recycle-settings-section">
      <h2 data-i18n="general">General</h2>
      <dl>
        <dt data-i18n="enable">Enable plugin</dt>
        <dd>
          <label><input type="checkbox" name="enabled" value="1"> <span data-i18n="enabled">Enabled</span></label>
          <span class="hint" data-i18n="enableHint">Controls the DFM recycle action and scheduled cleanup.</span>
        </dd>
      </dl>
    </section>

    <section class="recycle-settings-section">
      <h2 data-i18n="volumes">Managed disks and datasets</h2>
      <dl>
        <dt data-i18n="enabledVolumes">Enabled volumes</dt>
        <dd>
          <div id="recycle-settings-volumes" class="recycle-volume-list"></div>
          <span class="hint" data-i18n="volumesHint">Only verified internal array disks and local ZFS datasets can be selected.</span>
        </dd>
      </dl>
    </section>

    <section class="recycle-settings-section">
      <h2 data-i18n="logging">Logging</h2>
      <dl>
        <dt><label for="recycle-log-level" data-i18n="logLevel">Log level</label></dt>
        <dd>
          <select id="recycle-log-level" name="log_level">
            <option value="ERROR">ERROR</option>
            <option value="WARN">WARN</option>
            <option value="INFO">INFO</option>
            <option value="DEBUG">DEBUG</option>
          </select>
        </dd>
        <dt><label for="recycle-log-retention" data-i18n="logRetention">Log retention (days)</label></dt>
        <dd><input id="recycle-log-retention" type="number" name="log_retention_days" min="0" max="3650"></dd>
        <dt><label for="recycle-log-size" data-i18n="logSize">Log size cap (MiB)</label></dt>
        <dd><input id="recycle-log-size" type="number" name="log_max_size_mib" min="1" max="100"></dd>
      </dl>
    </section>

    <section class="recycle-settings-section">
      <h2 data-i18n="history">History</h2>
      <dl>
        <dt data-i18n="recordHistory">Record history</dt>
        <dd>
          <label><input type="checkbox" name="history_enabled" value="1"> <span data-i18n="enabled">Enabled</span></label>
          <span class="hint" data-i18n="historyHint">Keep audit rows after an item is restored or permanently deleted. Active recycle records are always retained.</span>
        </dd>
        <dt><label for="recycle-history-retention" data-i18n="historyRetention">History retention (days)</label></dt>
        <dd>
          <input id="recycle-history-retention" type="number" name="history_retention_days" min="0" max="36500">
          <span class="hint" data-i18n="historyRetentionHint">0 keeps restored and purged audit rows indefinitely.</span>
        </dd>
      </dl>
    </section>

    <section class="recycle-settings-section">
      <h2 data-i18n="maintenance">Maintenance</h2>
      <p class="hint" data-i18n="maintenanceHint">Maintenance runs only with the configured cleanup schedule or an explicit manual action.</p>
      <dl>
        <dt><label for="recycle-age-days" data-i18n="ageDays">Age eviction (days)</label></dt>
        <dd>
          <input id="recycle-age-days" type="number" name="age_days" min="0" max="36500">
          <span class="hint" data-i18n="ageDaysHint">Permanently deletes active recycle items older than this during maintenance. 0 disables age eviction.</span>
        </dd>
        <dt><label for="recycle-capacity-mode" data-i18n="capacityMode">Capacity mode</label></dt>
        <dd>
          <select id="recycle-capacity-mode" name="capacity_mode">
            <option value="percent" data-i18n="percent">Percent</option>
            <option value="absolute" data-i18n="absolute">Absolute (GiB)</option>
          </select>
        </dd>
        <dt><label for="recycle-capacity-percent" data-i18n="capacityPercent">Capacity percent (%)</label></dt>
        <dd>
          <input id="recycle-capacity-percent" type="number" name="capacity_percent" min="0" max="100">
          <span class="hint" data-i18n="capacityPercentHint">Maximum recycle-bin share of each volume. 0 disables this limit.</span>
        </dd>
        <dt><label for="recycle-capacity-absolute" data-i18n="capacityAbsolute">Capacity absolute (GiB)</label></dt>
        <dd>
          <input id="recycle-capacity-absolute" type="number" name="capacity_absolute_gb" min="0" max="1048576">
          <span class="hint" data-i18n="capacityAbsoluteHint">0 means no absolute capacity limit, not zero available space.</span>
        </dd>
        <dt><label for="recycle-cron" data-i18n="scheduledCleanup">Scheduled cleanup (cron)</label></dt>
        <dd>
          <input id="recycle-cron" type="text" name="auto_empty_cron" placeholder="0 3 * * 0">
          <span class="hint" data-i18n="cronHint">Example: 0 3 * * 0 runs every Sunday at 03:00. Empty disables scheduled work.</span>
        </dd>
        <dt data-i18n="vacuum">Vacuum SQLite</dt>
        <dd>
          <label><input type="checkbox" name="vacuum_sqlite" value="1"> <span data-i18n="enabled">Enabled</span></label>
          <span class="hint" data-i18n="vacuumHint">Reclaims unused database pages during scheduled maintenance. It may briefly increase disk I/O and lock the history database.</span>
        </dd>
      </dl>
    </section>

    <section class="recycle-settings-section">
      <h2 data-i18n="security">Security</h2>
      <dl>
        <dt data-i18n="preserveMetadata">Preserve metadata</dt>
        <dd>
          <label><input type="checkbox" name="preserve_metadata" value="1"> <span data-i18n="enabled">Enabled</span></label>
          <span class="hint" data-i18n="preserveMetadataHint">Restores the original owner, group, permissions and modification time. Disable only if restored files should inherit newly created defaults.</span>
        </dd>
      </dl>
    </section>

    <section class="recycle-settings-section">
      <h2 data-i18n="status">Status</h2>
