Menu='Buttons:5'
Title='Dynamix File Recycle Bin'
Link='recycle-runtime-hook'
---
<?php
/**
 * RecycleInject.page — header-injected loader for the recycle bin front-end.
 *
 * This file uses the official Unraid `Menu='Buttons'` page channel. The
 * DefaultPageLayout.php `find_pages('Buttons')` collects it and includes its
 * body into every page's <head>. We therefore do NOT modify HeadInlineJS.php,
 * Browse.page, or any dynamix file — we just ride the same channel the
 * official DFM BrowseButton.page (Buttons:3a) already uses.
 *
 * Rank 5 makes us load after DFM (3a). The front-end adds one batch action to
 * DFM's bottom control strip after the native Delete button and reuses DFM's
 * own `input.extra` selection-state handling.
 *
 * The injected JSON object `window.__recycleRuntime` carries:
 *   - csrfToken   string   (read from $var, NOT hardcoded in JS)
 *   - apiBase     string   '/plugins/dynamix.file.recycle/api.php'
 *   - lang        string   resolved language code
 *   - i18n        object   translations the JS needs
 *   - enabled     bool     master switch
 *
 * The script itself is loaded from javascript/recycle.js and is intentionally
 * self-contained (no jQuery dependency beyond what DFM already pulls in).
 */

$pluginRoot = '/plugins/dynamix.file.recycle';
$pluginDir  = '/usr/local/emhttp/plugins/dynamix.file.recycle';
$bootFile   = $pluginDir . '/include/Bootstrap.php';
if (!is_file($bootFile)) {
    return; // plugin partially uninstalled; bail silently.
}
require_once $bootFile;

// Merge the plugin-local title catalog before Unraid builds menu panels. This
// avoids depending on the global language-pack cache, which can be rebuilt by
// Unraid independently of third-party plugin installation.
$localeCode = strtolower((string) ($_SESSION['locale'] ?? ($GLOBALS['locale'] ?? 'en_US')));
if (str_starts_with($localeCode, 'zh')) {
    $catalog = @parse_ini_file(
        $pluginDir . '/unraid-language/zh_CN/dynamix.file.recycle.txt',
        false,
        INI_SCANNER_RAW
    );
    if (is_array($catalog)) {
        $baseLanguage = $GLOBALS['language'] ?? [];
        $GLOBALS['language'] = array_merge(is_array($baseLanguage) ? $baseLanguage : [], $catalog);
    }
}

try {
    $c = \DynamixFileRecycle\boot();
    $cfg = $c->config();
    $i18n = $c->i18n();
} catch (\Throwable $e) {
    error_log('Dynamix File Recycle Bin injection bootstrap failed: ' . $e->getMessage());
    return;
}
$enabled = $cfg->getEnabled();
$versionFile = $pluginDir . '/VERSION';
$version = is_file($versionFile) ? trim((string) file_get_contents($versionFile)) : 'unknown';

// Read CSRF token from Unraid state. Prefer $var (already-loaded dynamix
// globals), fall back to parsing var.ini ourselves.
$csrf = '';
if (isset($var) && is_array($var) && !empty($var['csrf_token'])) {
    $csrf = (string) $var['csrf_token'];
}
if ($csrf === '') {
    $varIni = '/usr/local/emhttp/state/var.ini';
    if (is_file($varIni)) {
        $parsed = @parse_ini_string((string) file_get_contents($varIni));
        if (is_array($parsed) && !empty($parsed['csrf_token'])) {
            $csrf = (string) $parsed['csrf_token'];
        }
    }
}

$runtime = [
    'csrfToken'  => $csrf,
    'apiBase'    => $pluginRoot . '/api.php',
    'lang'       => $i18n->lang(),
    'enabled'    => $enabled,
    'version'    => $version,
    'history'    => $cfg->getHistoryEnabled(),
    'i18n' => [
        'btnTitle'         => $i18n->t('btn.title'),
        'btnBatch'         => $i18n->t('btn.batch'),
        'btnTitleBlocked'  => $i18n->t('btn.title.blocked'),
        'btnTitleError'    => $i18n->t('btn.title.error'),
        'stateIdle'        => $i18n->t('state.idle'),
        'stateChecking'    => $i18n->t('state.checking'),
        'stateRunning'     => $i18n->t('state.running'),
        'stateBlocked'     => $i18n->t('state.blocked'),
        'stateError'       => $i18n->t('state.error'),
        'confirmRecycle'   => $i18n->t('confirm.recycle'),
        'confirmBatch'     => $i18n->t('confirm.batch'),
        'doneMessage'      => $i18n->t('done.message'),
        'doneBatch'        => $i18n->t('done.batch'),
        'errorMessage'     => $i18n->t('error.message'),
        'noSelection'      => $i18n->t('error.no_selection'),
        'errors' => [
            'unsupported_boot_device'       => $i18n->t('error.unsupported_boot_device'),
            'unsupported_user_share'        => $i18n->t('error.unsupported_user_share'),
            'unsupported_cache_pool'        => $i18n->t('error.unsupported_cache_pool'),
            'unsupported_unassigned_device' => $i18n->t('error.unsupported_unassigned_device'),
            'unsupported_remote_path'       => $i18n->t('error.unsupported_remote_path'),
            'unsupported_usb_storage'       => $i18n->t('error.unsupported_usb_storage'),
            'unsupported_removable_storage' => $i18n->t('error.unsupported_removable_storage'),
            'unverified_storage_topology'   => $i18n->t('error.unverified_storage_topology'),
            'unsupported_nested_mount'      => $i18n->t('error.unsupported_nested_mount'),
            'unsupported_symbolic_link'     => $i18n->t('error.unsupported_symbolic_link'),
            'unsupported_cross_filesystem'  => $i18n->t('error.unsupported_cross_filesystem'),
            'unsupported_path'              => $i18n->t('error.unsupported_path'),
            'volume_management_disabled'    => $i18n->t('error.volume_management_disabled'),
            'invalid_volume_selection'      => $i18n->t('error.invalid_volume_selection'),
        ],
        'settings' => [
            'intro' => $i18n->t('settings.intro'),
            'general' => $i18n->t('settings.general'),
            'enable' => $i18n->t('settings.enable'),
            'enabled' => $i18n->t('settings.enabled'),
            'enableHint' => $i18n->t('settings.enable_hint'),
            'volumes' => $i18n->t('settings.volumes'),
            'enabledVolumes' => $i18n->t('settings.enabled_volumes'),
            'volumesHint' => $i18n->t('settings.volumes_hint'),
            'noVolumes' => $i18n->t('settings.no_volumes'),
            'logging' => $i18n->t('settings.logging'),
            'logLevel' => $i18n->t('settings.log_level'),
            'logRetention' => $i18n->t('settings.log_retention'),
            'logSize' => $i18n->t('settings.log_size'),
            'history' => $i18n->t('settings.history'),
            'recordHistory' => $i18n->t('settings.record_history'),
            'historyRetention' => $i18n->t('settings.history_retention'),
            'maintenance' => $i18n->t('settings.maintenance'),
            'maintenanceHint' => $i18n->t('settings.maintenance_hint'),
            'ageDays' => $i18n->t('settings.age_days'),
            'capacityMode' => $i18n->t('settings.capacity_mode'),
            'percent' => $i18n->t('settings.percent'),
            'absolute' => $i18n->t('settings.absolute'),
            'capacityPercent' => $i18n->t('settings.capacity_percent'),
            'capacityAbsolute' => $i18n->t('settings.capacity_absolute'),
            'scheduledCleanup' => $i18n->t('settings.scheduled_cleanup'),
            'cronHint' => $i18n->t('settings.cron_hint'),
            'vacuum' => $i18n->t('settings.vacuum'),
            'security' => $i18n->t('settings.security'),
            'preserveMetadata' => $i18n->t('settings.preserve_metadata'),
            'status' => $i18n->t('settings.status'),
            'activeItems' => $i18n->t('settings.active_items'),
            'runtimeLog' => $i18n->t('settings.runtime_log'),
            'auditLog' => $i18n->t('settings.audit_log'),
            'sqliteLayout' => $i18n->t('settings.sqlite_layout'),
            'save' => $i18n->t('settings.save'),
            'openBin' => $i18n->t('settings.open_bin'),
            'loading' => $i18n->t('settings.loading'),
            'saving' => $i18n->t('settings.saving'),
            'saved' => $i18n->t('settings.saved'),
            'requestFailed' => $i18n->t('settings.request_failed'),
            'bytes' => $i18n->t('settings.bytes'),
        ],
    ],
];

$requestUri = (string) ($_SERVER['REQUEST_URI'] ?? '');
if (preg_match('#(?:^|/)Browse(?:[/?]|$)#', $requestUri) === 1) {
    $c->logger()->info(
        'ui_inject',
        '',
        sprintf('Browse assets emitted version=%s enabled=%d uri=%s', $version, $enabled ? 1 : 0, $requestUri)
    );
}

$runtimeJson = json_encode(
    $runtime,
    JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE
        | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT
);
?>
<link rel="stylesheet" href="<?autov('/plugins/dynamix.file.recycle/javascript/recycle.css')?>&amp;plugin=<?=rawurlencode($version)?>" data-recycle-asset="css">
<script>
window.__recycleRuntime = <?= $runtimeJson ?>;
</script>
<script src="<?autov('/plugins/dynamix.file.recycle/javascript/recycle.js')?>&amp;plugin=<?=rawurlencode($version)?>" data-recycle-asset="js"></script>
