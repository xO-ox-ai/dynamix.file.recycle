Menu="DiskUtilities:30"
Title="Recycle Bin"
Icon="recycle"
Tag="recycle"
---
<?php
// Like the settings page, this route renders before storage services start.
// Recycle data is loaded through api.php so an offline volume or SQLite error
// becomes an inline notice instead of an empty Unraid page.
$recycleBinPluginDir = '/usr/local/emhttp/plugins/dynamix.file.recycle';
require_once $recycleBinPluginDir . '/include/I18n.php';
$recycleBinI18n = new \DynamixFileRecycle\I18n($recycleBinPluginDir . '/languages', 'auto');
$recycleBinCatalog = [];
foreach ([
    'title' => 'bin.title',
    'refresh' => 'bin.refresh',
    'settings' => 'bin.settings',
    'loading' => 'bin.loading',
    'loadFailed' => 'bin.load_failed',
    'activeItems' => 'bin.active_items',
    'records' => 'bin.records',
    'historyOn' => 'bin.history_on',
    'historyOff' => 'bin.history_off',
    'state' => 'bin.state',
    'name' => 'bin.name',
    'originalPath' => 'bin.original_path',
    'volume' => 'bin.volume',
    'size' => 'bin.size',
    'deletedAt' => 'bin.deleted_at',
    'actions' => 'bin.actions',
    'empty' => 'bin.empty',
    'active' => 'bin.active',
    'restored' => 'bin.restored',
    'purged' => 'bin.purged',
    'pending' => 'bin.pending',
    'restoring' => 'bin.restoring',
    'purging' => 'bin.purging',
    'directory' => 'bin.directory',
    'restore' => 'bin.restore',
    'purge' => 'bin.purge',
    'managementDisabled' => 'bin.management_disabled',
    'missing' => 'bin.missing',
    'confirmRestore' => 'bin.confirm_restore',
    'confirmPurge' => 'bin.confirm_purge',
    'restoreDone' => 'bin.restore_done',
    'purgeDone' => 'bin.purge_done',
    'note' => 'bin.note',
] as $recycleBinKey => $recycleBinTranslationKey) {
    $recycleBinCatalog[$recycleBinKey] = $recycleBinI18n->t($recycleBinTranslationKey);
}
$recycleBinVar = $var ?? @parse_ini_file('/var/local/emhttp/var.ini') ?: [];
$recycleBinAssetVersion = is_file($recycleBinPluginDir . '/VERSION')
    ? trim((string) file_get_contents($recycleBinPluginDir . '/VERSION')) : 'dev';
$recycleBinRuntime = [
    'apiUrl' => '/plugins/dynamix.file.recycle/api.php',
    'csrfToken' => (string) ($recycleBinVar['csrf_token'] ?? ''),
    'settingsUrl' => '/Settings/DynamixFileRecycle',
    'i18n' => $recycleBinCatalog,
];
?>
<link rel="stylesheet" href="<?autov('/plugins/dynamix.file.recycle/javascript/recycle-bin.css')?>&amp;plugin=<?=rawurlencode($recycleBinAssetVersion)?>">

<div id="recycle-bin" class="recycle-bin">
  <div id="recycle-bin-notice" class="recycle-bin-notice" role="status" aria-live="polite"></div>

  <div class="recycle-bin-toolbar">
    <button type="button" id="recycle-bin-refresh"><i class="fa fa-refresh" aria-hidden="true"></i> <span data-i18n="refresh">Refresh</span></button>
    <button type="button" id="recycle-bin-settings"><i class="fa fa-cog" aria-hidden="true"></i> <span data-i18n="settings">Settings</span></button>
    <span id="recycle-bin-summary" class="hint"></span>
  </div>

  <div class="recycle-bin-table-wrap">
    <table id="recycle-bin-table">
      <thead>
        <tr>
          <th data-i18n="state">State</th>
          <th data-i18n="name">Name</th>
          <th data-i18n="originalPath">Original path</th>
          <th data-i18n="volume">Volume</th>
          <th data-i18n="size">Size</th>
          <th data-i18n="deletedAt">Deleted at</th>
          <th data-i18n="actions">Actions</th>
        </tr>
      </thead>
      <tbody id="recycle-bin-body">
        <tr><td colspan="7" class="recycle-bin-empty" data-i18n="loading">Loading recycle records...</td></tr>
      </tbody>
    </table>
  </div>

  <p class="hint recycle-bin-note" data-i18n="note">Only entries tracked in the per-volume SQLite databases are shown.</p>
</div>

<script>
window.DynamixFileRecycleBinRuntime = Object.freeze(<?=json_encode($recycleBinRuntime, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT)?>);
</script>
<script src="<?autov('/plugins/dynamix.file.recycle/javascript/recycle-bin.js')?>&amp;plugin=<?=rawurlencode($recycleBinAssetVersion)?>"></script>
