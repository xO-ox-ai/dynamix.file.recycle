        <dt data-i18n="runtimeLog">Runtime log</dt>
        <dd><code>/usr/local/emhttp/state/plugins/dynamix.file.recycle/logs/dynamix.file.recycle.log</code></dd>
        <dt data-i18n="auditLog">Persistent error audit</dt>
        <dd><code>/boot/config/plugins/dynamix.file.recycle/logs/audit.log</code></dd>
        <dt data-i18n="sqliteLayout">SQLite layout</dt>
        <dd><code>&lt;volume&gt;/.RecycleBin/.dynamix-file-recycle.sqlite</code></dd>
      </dl>
    </section>

    <div class="recycle-settings-actions">
      <button type="submit"><i class="fa fa-save" aria-hidden="true"></i> <span data-i18n="save">Save</span></button>
      <button type="button" id="recycle-open-bin"><i class="fa fa-folder-open" aria-hidden="true"></i> <span data-i18n="openBin">Open Recycle Bin</span></button>
      <button type="button" id="recycle-clear-logs"><i class="fa fa-file-text-o" aria-hidden="true"></i> <span data-i18n="clearLogs">Clear logs</span></button>
      <button type="button" id="recycle-clear-history" class="recycle-danger"><i class="fa fa-history" aria-hidden="true"></i> <span data-i18n="clearHistory">Clear deleted-item history</span></button>
    </div>
    <p class="hint recycle-action-help"><span data-i18n="clearLogsHint">Clear runtime, persistent audit and SQLite event logs.</span></p>
    <p class="hint recycle-action-help"><span data-i18n="clearHistoryHint">Deletes only restored and purged history rows. Active recycle items and files are preserved.</span></p>
  </form>
</div>

